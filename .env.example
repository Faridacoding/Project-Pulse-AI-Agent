# .env.example — copy to .env and fill in your values
# No Anthropic API key needed — uses Claude Pro plan via Claude Code CLI.

# Google Drive & Calendar (optional) — get credentials at https://console.cloud.google.com
# 1. Create a project → Enable these APIs: Google Drive API, Google Slides API, Google Calendar API
# 2. OAuth 2.0 Client ID → Application type: Web → Redirect URI: http://localhost:3001/api/auth/google/callback
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# Email invitations (optional) — SMTP credentials for sending .ics calendar invites
# Gmail: enable 2FA on your Google account, then generate an App Password at
#   https://myaccount.google.com/apppasswords and use it as SMTP_PASS
SMTP_USER=your_smtp_email_here
SMTP_PASS=your_smtp_app_password_here

# Optional SMTP overrides (defaults work for Gmail STARTTLS on port 587)
# For Gmail SSL use: SMTP_HOST=smtp.gmail.com  SMTP_PORT=465  SMTP_SECURE=true
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
